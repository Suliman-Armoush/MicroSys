<div class="nav-brand-row">
    <a class="navbar-brand" href="">
        <span class="brand-mark">MS</span>
        <span>
            <strong>MicroSys</strong>
            <small>Network Management</small>
        </span>
    </a>

    <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
        <span></span>
        <span></span>
        <span></span>
    </button>
</div>

<div class="@($"nav-scrollable {NavMenuCssClass}")" @onclick="ToggleNavMenu" style="color:white">
    <nav class="nav-stack">
        <AuthorizeView Context="authContext" Roles="Admin">
            <Authorized>
                <div class="nav-section-label">Workspace</div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="nav-icon nav-home" aria-hidden="true"></span>
                        <span>Dashboard</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <button class="nav-link nav-button @(expandMikrotik ? "active-parent" : "")"
                            type="button"
                            @onclick="ToggleMikrotikMenu"
                            @onclick:stopPropagation>
                        <span class="nav-icon nav-network" aria-hidden="true"></span>
                        <span class="flex-grow-1">Mikrotik</span>
                        <span class="nav-chevron @(expandMikrotik ? "open" : "")" aria-hidden="true"></span>
                    </button>
                </div>

                @if (expandMikrotik)
                {
                    <div class="submenu-container">
                        <div class="nav-item">
                            <NavLink class="nav-link submenu-link" href="mikrotik-users">
                                <span class="nav-icon nav-users" aria-hidden="true"></span>
                                <span>Network Users</span>
                            </NavLink>
                        </div>

                        <div class="nav-item">
                            <NavLink class="nav-link submenu-link" href="mikrotik-hosts">
                                <span class="nav-icon nav-hosts" aria-hidden="true"></span>
                                <span>Connected Hosts</span>
                            </NavLink>
                        </div>

                        <div class="nav-item">
                            <NavLink class="nav-link submenu-link" href="reports">
                                <span class="nav-icon nav-reports" aria-hidden="true"></span>
                                <span>Reports</span>
                            </NavLink>
                        </div>
                    </div>
                }

                <div class="nav-section-label">Administration</div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="users">
                        <span class="nav-icon nav-users" aria-hidden="true"></span>
                        <span>Users</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="roles">
                        <span class="nav-icon nav-roles" aria-hidden="true"></span>
                        <span>Roles</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="departments">
                        <span class="nav-icon nav-departments" aria-hidden="true"></span>
                        <span>Departments</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="sysInfos">
                        <span class="nav-icon nav-settings" aria-hidden="true"></span>
                        <span>Settings</span>
                    </NavLink>
                </div>

                <div class="nav-spacer"></div>

                <div class="nav-user">
                    <span class="nav-user-label">Signed in</span>
                    <span class="nav-user-email">@authContext.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</span>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link logout-link" href="logout">
                        <span class="nav-icon nav-logout" aria-hidden="true"></span>
                        <span>Sign Out</span>
                    </NavLink>
                </div>
            </Authorized>

        </AuthorizeView>

        <AuthorizeView Context="managerContext" Roles="Manager">
            <Authorized>
                <div class="nav-section-label">Manager</div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="manager" Match="NavLinkMatch.All">
                        <span class="nav-icon nav-home" aria-hidden="true"></span>
                        <span>My Department</span>
                    </NavLink>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link" href="manager/users">
                        <span class="nav-icon nav-users" aria-hidden="true"></span>
                        <span>Department Users</span>
                    </NavLink>
                </div>

                <div class="nav-spacer"></div>

                <div class="nav-user">
                    <span class="nav-user-label">Signed in</span>
                    <span class="nav-user-email">@managerContext.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</span>
                </div>

                <div class="nav-item">
                    <NavLink class="nav-link logout-link" href="logout">
                        <span class="nav-icon nav-logout" aria-hidden="true"></span>
                        <span>Sign Out</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView>
            <NotAuthorized>
                <div class="nav-section-label">Access</div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="login">
                        <span class="nav-icon nav-login" aria-hidden="true"></span>
                        <span>Sign In</span>
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool expandMikrotik = false;

    private string NavMenuCssClass => collapseNavMenu ? "collapse" : string.Empty;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void ToggleMikrotikMenu()
    {
        expandMikrotik = !expandMikrotik;
        if (expandMikrotik)
        {
            collapseNavMenu = false;
        }
    }
}
