<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">MicroSys</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <AuthorizeView Context="authContext">
            <Authorized>
                @* Home *@
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="oi oi-home" aria-hidden="true"></span> Home
                    </NavLink>
                </div>

                @* Mikrotik Dropdown *@
                <div class="nav-item px-3">
                    <div class="nav-link dropdown-toggle-custom @(expandMikrotik ? "active-parent" : "")"
                         @onclick="ToggleMikrotikMenu" @onclick:stopPropagation>
                        <span class="oi oi-wifi" aria-hidden="true"></span>
                        <span class="flex-grow-1 ms-2">Mikrotik</span>
                        <span class="oi @(expandMikrotik ? "oi-chevron-bottom" : "oi-chevron-left")"
                              style="font-size: 0.7rem; transition: transform 0.3s;"></span>
                    </div>
                </div>

                @if (expandMikrotik)
                {
                    <div class="submenu-container">
                        @* 1. Users *@
                        <div class="nav-item px-3 ms-3">
                            <NavLink class="nav-link submenu-link" href="mikrotik-users">
                                <span class="oi oi-people me-2" aria-hidden="true"></span> Users
                            </NavLink>
                        </div>
                        
                        @* 2. Hosts *@
                        <div class="nav-item px-3 ms-3">
                            <NavLink class="nav-link submenu-link" href="mikrotik-hosts">
                                <span class="bi bi-laptop me-2" aria-hidden="true"></span> Hosts
                            </NavLink>
                        </div>

                        @* 3. Reports *@
                        <div class="nav-item px-3 ms-3">
                            <NavLink class="nav-link submenu-link" href="reports">
                                <span class="oi oi-document me-2" aria-hidden="true"></span> Reports
                            </NavLink>
                        </div>
                    </div>
                }

                @* Role *@
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="roles">
                        <span class="oi oi-person" aria-hidden="true"></span> Roles
                    </NavLink>
                </div>

                @* Department *@
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="departments">
                        <span class="oi oi-briefcase" aria-hidden="true"></span> Departments
                    </NavLink>
                </div>

                @* Settings *@
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="sysInfos">
                        <span class="oi oi-briefcase" aria-hidden="true"></span> Settings
                    </NavLink>
                </div>

                @* Logout *@
                <div class="nav-item px-3 mt-auto">
                    <NavLink class="nav-link logout-link text-danger" href="logout">
                        <span class="oi oi-account-logout" aria-hidden="true"></span>
                        <small class="ms-1 text-truncate">
                            Logout (@authContext.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value)
                        </small>
                    </NavLink>
                </div>
            </Authorized>
            
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        <span class="oi oi-account-login" aria-hidden="true"></span> Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool expandMikrotik = false;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void ToggleMikrotikMenu()
    {
        expandMikrotik = !expandMikrotik;
        if (expandMikrotik)
        {
            collapseNavMenu = false;
        }
    }
}

<style>
    /* تنسيق الحاوية الرئيسية للقائمة الفرعية */
    .submenu-container {
        background-color: rgba(0, 0, 0, 0.2);
        margin: 5px 15px;
        border-radius: 8px;
        padding: 5px 0;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    /* توحيد شكل الروابط الفرعية */
    .submenu-link {
        color: #adb5bd !important;
        font-size: 0.85rem !important;
        padding: 8px 15px !important;
        display: flex !important;
        align-items: center;
        transition: all 0.2s ease;
    }

        .submenu-link:hover {
            color: white !important;
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 5px;
            padding-left: 20px !important;
        }

    /* تنسيق زر القائمة المنسدلة الرئيسي */
    .dropdown-toggle-custom {
        display: flex;
        align-items: center;
        cursor: pointer;
        padding: 0.5rem 1rem;
        border-radius: 4px;
        color: #d7d7d7;
        transition: all 0.2s ease;
    }

    .active-parent {
        background-color: rgba(0, 123, 255, 0.2);
        border-right: 4px solid #007bff; /* لتحديد القائمة المفتوحة */
        color: white;
    }
</style>