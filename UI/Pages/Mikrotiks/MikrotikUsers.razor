@page "/mikrotik-users"
@using UI.Models.Response
@using UI.Services.Interfaces
@inject IMikrotikService MikrotikService

<PageTitle>مستخدمي الميكروتيك</PageTitle>

<div class="container-fluid mt-4">
    @* قسم العنوان وزر الإضافة *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark m-0">مستخدمي الميكروتيك</h3>
        <button class="btn btn-primary shadow-sm px-4 fw-bold" @onclick="() => showModal = true">
            <i class="bi bi-plus-lg"></i> إضافة مستخدم جديد
        </button>
    </div>

    @* جدول العرض المصمم حسب الصورة *@
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-muted">
                            <th class="ps-4 py-3 text-start">المستخدم (Username)</th>
                            <th class="text-start">الملاحظات (Comment)</th>
                            <th class="text-center">رفع (Upload GB)</th>
                            <th class="text-center">تحميل (Download GB)</th>
                            <th class="text-end pe-4">الإجمالي (Total GB)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (users == null)
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="spinner-border text-primary" role="status"></div>
                                    <p class="mt-2 text-muted">جاري تحميل البيانات من السيرفر...</p>
                                </td>
                            </tr>
                        }
                        else if (!users.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    لا يوجد مستخدمين لعرضهم حالياً.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in users)
                            {
                                <tr>
                                    <td class="ps-4 py-3 text-start">
                                        <span class="text-primary fw-bold" style="cursor: pointer;">@user.Username</span>
                                    </td>
                                    <td class="text-muted small text-start">@user.Comment</td>
                                    @* البيانات تعرض مباشرة لأن الباك إند يرسلها مقسومة على 1024^3 *@
                                    <td class="text-center text-danger">
                                        @user.BytesIn.ToString("N2")
                                    </td>
                                    <td class="text-center text-success">
                                        @user.BytesOut.ToString("N2")
                                    </td>
                                    <td class="text-end pe-4">
                                        <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm" style="min-width: 100px; font-size: 0.9rem;">
                                            @user.Total.ToString("N2") GB
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* استدعاء الـ Component المستقل للإضافة *@
<CreateMikrotikUserModal 
    IsVisible="showModal" 
    OnClose="() => showModal = false" 
    OnUserCreated="ReloadUsers" />

@code {
    private List<MikrotikUserResponseDto>? users;
    private bool showModal = false;

    // جلب البيانات عند تشغيل الصفحة لأول مرة
    protected override async Task OnInitializedAsync()
    {
        await ReloadUsers();
    }

    // دالة إعادة تحميل البيانات وتحديث الواجهة
    private async Task ReloadUsers()
    {
        try 
        {
            // نضع نول لإظهار علامة التحميل أثناء الجلب الجديد
            users = null; 
            StateHasChanged();

            users = await MikrotikService.GetAllUsersAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error reloading users: {ex.Message}");
            users = new List<MikrotikUserResponseDto>();
        }
        finally
        {
            StateHasChanged();
        }
    }
}