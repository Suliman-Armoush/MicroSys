@page "/mikrotik-users"
@using UI.Models.Response
@using UI.Services.Interfaces
@inject IMikrotikService MikrotikService

<PageTitle>مستخدمي الميكروتيك</PageTitle>

<div class="container-fluid mt-4">
    @* رأس الصفحة *@
    <div class="d-flex justify-content-between align-items-center mb-4" dir="rtl">
        <h3 class="fw-bold text-dark m-0">مستخدمي الميكروتيك</h3>
        <button class="btn btn-primary shadow-sm px-4 fw-bold" @onclick="() => showCreateModal = true">
            إضافة مستخدم جديد
        </button>
    </div>

    @* الجدول المقلوب بالكامل *@
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-end" dir="rtl">
                    <thead class="bg-light">
                        <tr class="text-dark fw-bold">
                            @* عكس ترتيب العناوين *@
                            <th class="py-3 pe-4 text-center" style="width: 10%;">الإجراءات</th>
                            <th class="text-center" style="width: 15%;">الإجمالي (Total GB)</th>
                            <th class="text-center" style="width: 12%;">تحميل (Download GB)</th>
                            <th class="text-center" style="width: 12%;">رفع (Upload GB)</th>
                            <th class="text-start" style="width: 25%;">الملاحظات (Comment)</th>
                            <th class="text-start ps-4" style="width: 20%;">المستخدم (Username)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (users == null)
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="spinner-border text-primary" role="status"></div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in users)
                            {
                                <tr>
                                    @* 1. الإجراءات (أصبحت في أقصى اليمين) *@
                                    <td class="pe-4 text-center">
                                        <button class="btn btn-sm btn-outline-warning fw-bold px-3 shadow-sm" 
                                                @onclick="() => OpenEditModal(user.Username)">
                                            تعديل
                                        </button>
                                    </td>

                                    @* 2. الإجمالي *@
                                    <td class="text-center">
                                        <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm" style="min-width: 95px;">
                                            GB @user.Total.ToString("N2")
                                        </span>
                                    </td>

                                    @* 3. تحميل (أخضر) *@
                                    <td class="text-center text-success fw-bold">
                                        @user.BytesOut.ToString("N2")
                                    </td>

                                    @* 4. رفع (أحمر) *@
                                    <td class="text-center text-danger fw-bold">
                                        @user.BytesIn.ToString("N2")
                                    </td>

                                    @* 5. الملاحظات *@
                                    <td class="text-start text-muted small">@user.Comment</td>

                                    @* 6. المستخدم (أصبح في أقصى اليسار) *@
                                    <td class="text-start ps-4">
                                        <span class="text-primary fw-bold">@user.Username</span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* المودالات *@
<CreateMikrotikUserModal 
    IsVisible="showCreateModal" 
    OnClose="() => showCreateModal = false" 
    OnUserCreated="ReloadUsers" />

<EditMikrotikUserModal 
    IsVisible="showEditModal" 
    CurrentUsername="@selectedUsername" 
    OnClose="() => showEditModal = false" 
    OnUserUpdated="ReloadUsers" />

@code {
    private List<MikrotikUserResponseDto>? users;
    private bool showCreateModal = false;
    private bool showEditModal = false;
    private string selectedUsername = "";

    protected override async Task OnInitializedAsync() => await ReloadUsers();

    private void OpenEditModal(string username)
    {
        selectedUsername = username;
        showEditModal = true;
    }

    private async Task ReloadUsers()
    {
        users = null;
        StateHasChanged();
        users = await MikrotikService.GetAllUsersAsync();
        StateHasChanged();
    }
}