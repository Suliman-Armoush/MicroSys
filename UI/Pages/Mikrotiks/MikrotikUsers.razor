@page "/mikrotik-users"
@attribute [Authorize(Roles = "Admin")]
@using UI.Models.Response
@using UI.Services.Interfaces
@inject IMikrotikService MikrotikService
@inject NavigationManager Navigation

<div class="container-fluid mt-4">
    @* --- Header Section --- *@
    <div class="d-flex justify-content-between align-items-center mb-4" dir="rtl">

        <!-- اليمين: الرجوع + العنوان -->
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-outline-dark px-3 shadow-sm d-flex align-items-center gap-2"
                    @onclick='() => Navigation.NavigateTo("/")'>
                <i class="bi bi-arrow-right"></i>
                <span>الرجوع</span>
            </button>

            <h3 class="fw-bold m-0">مستخدمي الميكروتيك</h3>
        </div>

        <!-- الوسط: البحث -->
        <div class="search-wrapper position-relative" style="width: 350px;">
            <input type="text"
                   class="form-control rounded-pill ps-5 py-2 border-primary shadow-none"
                   placeholder="بحث عن مستخدم..."
                   @bind="searchTerm"
                   @bind:event="oninput"
                   @onkeyup="HandleSearch" />
        </div>

        <!-- اليسار: الأزرار -->
        <div class="d-flex gap-2">
            <button class="btn btn-primary shadow-sm px-4 fw-bold"
                    @onclick="() => showCreateModal = true">
                إضافة مستخدم جديد
            </button>
            <button class="btn btn-danger shadow-sm px-4 fw-bold"
                    @onclick="() => showResetAllCountersModal = true">
                ترسيت جميع العدادات
            </button>
        </div>
    </div>

    @* --- Table Section (نفس تصميمك الأصلي) --- *@
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0 text-end" dir="rtl">
                    <thead class="bg-light fw-bold">
                        <tr>
                            <th class="py-3 text-center">الإجراءات</th>
                            <th class="text-center">الإجمالي (Total GB)</th>
                            <th class="text-center">تحميل (Download GB)</th>
                            <th class="text-center">رفع (Upload GB)</th>
                            <th class="text-start">الملاحظات (Comment)</th>
                            <th class="text-start ps-3">المستخدم (Username)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (users == null)
                        {
                            <tr><td colspan="6" class="text-center py-5"><div class="spinner-border text-primary"></div></td></tr>
                        }
                        else
                        {
                            @foreach (var user in users)
                            {
                                <tr>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1">
                                            <button class="btn btn-sm btn-outline-success" @onclick="() => OpenEnableModal(user.Username)">تفعيل</button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenDisableModal(user.Username)">تعطيل</button>
                                            <button class="btn btn-sm btn-outline-warning" @onclick="() => OpenEditModal(user.Username)">تعديل</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => OpenDeleteModal(user.Username)">حذف</button>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill bg-primary px-3 py-2">GB @user.Total.ToString("N2")</span>
                                    </td>
                                    <td class="text-center fw-bold" style="color: #28a745;">@user.BytesOut.ToString("N2")</td>
                                    <td class="text-center fw-bold" style="color: #dc3545;">@user.BytesIn.ToString("N2")</td>
                                    <td class="text-start text-muted">@user.Comment</td>
                                    <td class="text-start ps-3 fw-bold text-primary">@user.Username</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* المودالات *@
<CreateMikrotikUserModal IsVisible="showCreateModal" OnClose="() => showCreateModal = false" OnUserCreated="ReloadUsers" />
<EditMikrotikUserModal IsVisible="showEditModal" CurrentUsername="@selectedUsername" OnClose="() => showEditModal = false" OnUserUpdated="ReloadUsers" />
<DeleteMikrotikUserModal IsVisible="showDeleteModal" Username="@selectedUsername" OnClose="() => showDeleteModal = false" OnUserDeleted="ReloadUsers" />
<EnableUserModal IsVisible="showEnableModal" Username="@selectedUsername" OnClose="() => showEnableModal = false" OnUserEnabled="ReloadUsers" />
<DisableUserModal IsVisible="showDisableModal" Username="@selectedUsername" OnClose="() => showDisableModal = false" OnUserDisabled="ReloadUsers" />
@if (showResetAllCountersModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);" dir="rtl">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">

                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title fw-bold">تأكيد ترسيت جميع العدادات</h5>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="CloseResetModal"></button>
                </div>

                <div class="modal-body text-center p-4">
                    <p class="fw-bold text-danger mb-3">
                        هذا الإجراء سيقوم بترسيت جميع عدادات المستخدمين نهائيًا
                    </p>

                    <p class="text-muted">
                        للمتابعة اكتب الكلمة التالية:
                    </p>

                    <div class="alert alert-light border fw-bold fs-5">
                        reset
                    </div>

                    <input type="text"
                           class="form-control text-center"
                           placeholder="اكتب reset هنا"
                           @bind="resetConfirmationText" />
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary"
                            @onclick="CloseResetModal">
                        إلغاء
                    </button>

                    <button class="btn btn-danger"
                            disabled="@(resetConfirmationText?.Trim().ToLower() != "reset")"
                            @onclick="ConfirmResetAllCounters">
                        تنفيذ الترسيت
                    </button>
                </div>

            </div>
        </div>
    </div>
}
<style>
    /* لمسة جمالية إضافية لصندوق البحث */
    .search-wrapper input:focus {
        background-color: #f8f9fa;
        box-shadow: 0 4px 10px rgba(13, 110, 253, 0.15) !important;
    }
</style>

@code {
    private List<MikrotikUserResponseDto>? users;
    private string searchTerm = "";
    private bool isSearching = false;
    private System.Timers.Timer? debounceTimer;
    private bool showCreateModal, showEditModal, showDeleteModal, showEnableModal, showDisableModal;
    private string selectedUsername = "";
    private bool showResetAllCountersModal = false;
    private string resetConfirmationText = "";


    protected override async Task OnInitializedAsync() => await ReloadUsers();

    private void HandleSearch()
    {
        debounceTimer?.Stop();
        debounceTimer = new System.Timers.Timer(400);
        debounceTimer.Elapsed += async (s, e) =>
        {
            isSearching = true;
            await InvokeAsync(StateHasChanged);
            users = string.IsNullOrWhiteSpace(searchTerm)
                ? await MikrotikService.GetAllUsersAsync()
                : await MikrotikService.SearchUsersAsync(searchTerm);
            isSearching = false;
            await InvokeAsync(StateHasChanged);
        };
        debounceTimer.AutoReset = false;
        debounceTimer.Start();
    }

    private async Task ReloadUsers()
    {
        users = null; StateHasChanged();
        users = await MikrotikService.GetAllUsersAsync();
        StateHasChanged();
    }

    private void CloseResetModal()
    {
        showResetAllCountersModal = false;
        resetConfirmationText = "";
    }

    private async Task ConfirmResetAllCounters()
    {
        var result = await MikrotikService.ResetAllCountersAsync();

        if (result)
        {
            await ReloadUsers();
        }

        CloseResetModal();
    }

    private void OpenEditModal(string u) { selectedUsername = u; showEditModal = true; }
    private void OpenDeleteModal(string u) { selectedUsername = u; showDeleteModal = true; }
    private void OpenEnableModal(string u) { selectedUsername = u; showEnableModal = true; }
    private void OpenDisableModal(string u) { selectedUsername = u; showDisableModal = true; }
}
