@using UI.Services.Interfaces
@inject IMikrotikService MikrotikService

@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title fw-bold">تأكيد الحذف</h5>
                </div>
                <div class="modal-body text-end py-4" dir="rtl">
                    <p class="mb-0">هل أنت متأكد من حذف المستخدم <span class="fw-bold text-danger">@Username</span>؟</p>
                    <small class="text-muted">هذا الإجراء لا يمكن التراجع عنه.</small>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light px-4" @onclick="Close">إلغاء</button>
                    <button type="button" class="btn btn-danger px-4 fw-bold" @onclick="ConfirmDelete" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        تأكيد الحذف
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Username { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnUserDeleted { get; set; }

    private bool isSubmitting = false;

    private async Task ConfirmDelete()
    {
        isSubmitting = true;
        var success = await MikrotikService.DeleteUserAsync(Username);
        if (success)
        {
            await OnUserDeleted.InvokeAsync();
            await Close();
        }
        isSubmitting = false;
    }

    private async Task Close() => await OnClose.InvokeAsync();
}