@using UI.Models.Request
@using UI.Models.Response
@using UI.Services.Interfaces
@inject IMikrotikService MikrotikService
@inject IDepartmentService DepartmentService

@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg text-end" dir="rtl">
                
                @* الهيدر: النص يمين والإكس يسار *@
                <div class="modal-header bg-warning text-dark d-flex align-items-center justify-content-between px-4 py-3">
                    <h5 class="modal-title fw-bold m-0">تعديل المستخدم: @CurrentUsername</h5>
                    <button type="button" class="btn-close ms-0 me-0" @onclick="Close" style="filter: brightness(0);"></button>
                </div>

                <EditForm Model="updateModel" OnValidSubmit="HandleUpdate">
                    <DataAnnotationsValidator />
                    
                    <div class="modal-body p-4">
                        @if (isLoading)
                        {
                            <div class="text-center py-5">
                                <div class="spinner-border text-warning" role="status"></div>
                                <p class="mt-2 text-muted">جاري تحميل البيانات...</p>
                            </div>
                        }
                        else
                        {
                            <div class="row">
                                @* اسم المستخدم وكلمة المرور *@
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small">اسم المستخدم الجديد</label>
                                    <InputText @bind-Value="updateModel.NewUsername" class="form-control" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small">كلمة المرور الجديدة</label>
                                    <InputText @bind-Value="updateModel.Password" class="form-control" placeholder="اتركه فارغاً لعدم التغيير" />
                                </div>

                                @* السيرفر والبروفايل *@
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small">السيرفر</label>
                                    <InputSelect @bind-Value="updateModel.Server" class="form-select">
                                        <option value="">-- اختر السيرفر --</option>
                                        @foreach (var srv in servers)
                                        {
                                            <option value="@srv.Name">@srv.Name</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small">البروفايل</label>
                                    <InputSelect @bind-Value="updateModel.Profile" class="form-select">
                                        <option value="">-- اختر البروفايل --</option>
                                        @foreach (var prof in profiles)
                                        {
                                            <option value="@prof.Name">@prof.Name</option>
                                        }
                                    </InputSelect>
                                </div>

                                @* القسم والحد الأقصى مع لاحقة GB *@
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small">القسم</label>
                                    <InputSelect @bind-Value="updateModel.DepartmentId" class="form-select">
                                        <option value="0">-- اختر القسم --</option>
                                        @foreach (var dept in departments)
                                        {
                                            <option value="@dept.Id">@dept.Name</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small">الحد الأقصى (Limit GB)</label>
                                    <div class="input-group" dir="ltr">
                                        <span class="input-group-text bg-light text-muted fw-bold">GB</span>
                                        <InputNumber @bind-Value="updateModel.LimitGB" class="form-control text-end" />
                                    </div>
                                </div>

                                @* التفاصيل بعرض كامل *@
                                <div class="col-12 mb-3">
                                    <label class="form-label fw-bold small">ملاحظات (Comment)</label>
                                    <InputText @bind-Value="updateModel.UserDetails" class="form-control" />
                                </div>
                            </div>
                        }
                    </div>

                    <div class="modal-footer bg-light d-flex justify-content-start gap-2">
                        <button type="submit" class="btn btn-warning px-4 fw-bold shadow-sm" disabled="@isLoading">حفظ التعديلات</button>
                        <button type="button" class="btn btn-secondary px-4 fw-bold" @onclick="Close">إلغاء</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string CurrentUsername { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnUserUpdated { get; set; }

    private UpdateMikrotikUserRequestDto updateModel = new();
    private List<MikrotikProfileResponseDto> profiles = new();
    private List<MikrotikServerResponseDto> servers = new();
    private List<DepartmentResponseDto> departments = new();
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !string.IsNullOrEmpty(CurrentUsername))
        {
            isLoading = true;
            await LoadAllInitialData();
            isLoading = false;
        }
    }

    private async Task LoadAllInitialData()
    {
        try
        {
            var pTask = MikrotikService.GetAllProfilesAsync();
            var sTask = MikrotikService.GetServersListAsync();
            var dTask = DepartmentService.GetAllAsync();
            var uTask = MikrotikService.GetUserByNameAsync(CurrentUsername);

            await Task.WhenAll(pTask, sTask, dTask, uTask);

            profiles = pTask.Result ?? new();
            servers = sTask.Result ?? new();
            departments = dTask.Result ?? new();
            
            var user = uTask.Result;
            if (user != null)
            {
                updateModel = new UpdateMikrotikUserRequestDto
                {
                    NewUsername = user.Username,
                    Profile = user.Profile,
                    Server = user.Server,
                    LimitGB = user.LimitGB,
                    UserDetails = user.Comment?.Contains("-") == true ? user.Comment.Split('-')[1].Trim() : user.Comment
                };
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private async Task HandleUpdate()
    {
        var result = await MikrotikService.UpdateUserAsync(CurrentUsername, updateModel);
        if (result != null)
        {
            await OnUserUpdated.InvokeAsync();
            await Close();
        }
    }

    private async Task Close() => await OnClose.InvokeAsync();
}