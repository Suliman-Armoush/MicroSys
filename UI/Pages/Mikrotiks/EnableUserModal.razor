@using UI.Services.Interfaces
@inject IMikrotikService MikrotikService

@if (IsVisible)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content border-0 shadow-lg">
                @* رأس المودال - لون أخضر للإشارة للتفعيل *@
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-person-check-fill me-2"></i> تفعيل مستخدم
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="Close" aria-label="Close"></button>
                </div>

                @* محتوى المودال *@
                <div class="modal-body text-end" dir="rtl">
                    <div class="py-3">
                        <p class="fs-5">هل أنت متأكد من رغبتك في <strong>إعادة تفعيل</strong> حساب المستخدم؟</p>
                        <div class="p-3 bg-light rounded border-start border-4 border-success mt-2">
                            <strong class="text-dark">اسم المستخدم: </strong>
                            <span class="text-success fw-bold">@Username</span>
                        </div>
                    </div>

                    @* تنبيه الخطأ - يظهر فقط في حال وجود رد من الـ Validator *@
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center mt-3 shadow-sm" role="alert">
                            <i class="bi bi-exclamation-circle-fill me-3 fs-4"></i>
                            <div>
                                <strong>تنبيه من النظام:</strong> @errorMessage
                            </div>
                        </div>
                    }
                </div>

                @* أزرار التحكم *@
                <div class="modal-footer bg-light border-top-0">
                    <button type="button" class="btn btn-outline-secondary px-4" @onclick="Close" disabled="@isSubmitting">
                        إلغاء
                    </button>
                    <button type="button" class="btn btn-success px-4 fw-bold shadow-sm" @onclick="HandleEnable" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>جاري التفعيل...</span>
                        }
                        else
                        {
                            <span>تأكيد التفعيل</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Username { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnUserEnabled { get; set; }

    private string errorMessage = "";
    private bool isSubmitting = false;

    private async Task HandleEnable()
    {
        isSubmitting = true;
        errorMessage = "";

        try
        {
            // استدعاء السيرفس الذي قمنا بتعديله ليعيد string?
            var errorResult = await MikrotikService.EnableUserAsync(Username);

            if (string.IsNullOrEmpty(errorResult))
            {
                // في حال عدم وجود نص خطأ، تعني العملية نجحت
                await OnUserEnabled.InvokeAsync();
                await Close();
            }
            else
            {
                // عرض رسالة الخطأ القادمة من الباك إند (مثل: This user is already enabled)
                errorMessage = errorResult;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "حدث خطأ أثناء محاولة الاتصال بالخادم.";
            Console.WriteLine($"Enable Error: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task Close()
    {
        errorMessage = ""; // تنظيف رسائل الخطأ عند الإغلاق
        await OnClose.InvokeAsync();
    }
}