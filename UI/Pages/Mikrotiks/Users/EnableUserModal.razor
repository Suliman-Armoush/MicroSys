@using UI.Services.Interfaces
@inject IMikrotikService MikrotikService

@if (IsVisible)
{
    <div class="modal fade show d-block app-modal-backdrop" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">
                        Enable User
                    </h5>
                    <button type="button" class="btn-close" @onclick="Close" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div class="py-3">
                        <p class="mb-3">Are you sure you want to <strong>enable</strong> this user account?</p>
                        <div class="p-3 border rounded bg-light">
                            <strong class="text-dark">Username: </strong>
                            <span class="text-success fw-bold">@Username</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-3" role="alert">
                            <strong>System notice:</strong> @errorMessage
                        </div>
                    }
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light px-4" @onclick="Close" disabled="@isSubmitting">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-success px-4 fw-bold" @onclick="HandleEnable" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Enabling...</span>
                        }
                        else
                        {
                            <span>Confirm Enable</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Username { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnUserEnabled { get; set; }

    private string errorMessage = "";
    private bool isSubmitting = false;

    private async Task HandleEnable()
    {
        isSubmitting = true;
        errorMessage = "";

        try
        {
            var errorResult = await MikrotikService.EnableUserAsync(Username);

            if (string.IsNullOrEmpty(errorResult))
            {
                await OnUserEnabled.InvokeAsync();
                await Close();
            }
            else
            {
                errorMessage = errorResult;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while contacting the server.";
            Console.WriteLine($"Enable Error: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task Close()
    {
        errorMessage = "";
        await OnClose.InvokeAsync();
    }
}
