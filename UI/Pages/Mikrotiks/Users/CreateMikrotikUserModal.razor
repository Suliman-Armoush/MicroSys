@using UI.Models.Request
@using UI.Models.Response
@using UI.Services.Interfaces
@inject IMikrotikService MikrotikService
@inject IDepartmentService DepartmentService

@if (IsVisible)
{
    <div class="modal fade show d-block app-modal-backdrop" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title fw-bold flex-grow-1">Add MikroTik User</h5>
                    <button type="button" class="btn-close" @onclick="Close" aria-label="Close" disabled="@isProcessing"></button>
                </div>

                <EditForm Model="createModel" OnValidSubmit="HandleSave">
                    <DataAnnotationsValidator />

                    <div class="modal-body p-4">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger mb-3">
                                @errorMessage
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Username</label>
                                <InputText @bind-Value="createModel.Username" class="form-control" />
                                <ValidationMessage For="@(() => createModel.Username)" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Password</label>
                                <InputText @bind-Value="createModel.Password" class="form-control" type="password" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Server</label>
                                <InputSelect @bind-Value="createModel.Server" class="form-select">
                                    <option value="">-- Select server --</option>
                                    @if (servers != null)
                                    {
                                        @foreach (var srv in servers)
                                        {
                                            <option value="@srv.Name">@srv.Name</option>
                                        }
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Profile</label>
                                <InputSelect @bind-Value="createModel.Profile" class="form-select">
                                    <option value="">-- Select profile --</option>
                                    @if (profiles != null)
                                    {
                                        @foreach (var prof in profiles)
                                        {
                                            <option value="@prof.Name">@prof.Name</option>
                                        }
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Department</label>
                                <InputSelect @bind-Value="createModel.DepartmentId" class="form-select">
                                    <option value="0">-- Select department --</option>
                                    @if (departments != null)
                                    {
                                        @foreach (var dept in departments)
                                        {
                                            <option value="@dept.Id">@dept.Name</option>
                                        }
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Limit GB</label>
                                <div class="input-group">
                                    <span class="input-group-text">GB</span>
                                    <InputNumber @bind-Value="createModel.LimitGB" class="form-control" />
                                </div>
                            </div>

                            <div class="col-12 mb-3">
                                <label class="form-label">Comments</label>
                                <InputTextArea @bind-Value="createModel.UserDetails" class="form-control" rows="2" />
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer d-flex justify-content-start gap-2 px-4 py-3">
                        <button type="submit" class="btn btn-primary px-4" disabled="@isProcessing">
                            @(isProcessing ? "Saving..." : "Save User")
                        </button>

                        <button type="button" class="btn btn-light px-4" @onclick="Close" disabled="@isProcessing">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnUserCreated { get; set; }

    private CreateMikrotikUserRequestDto createModel = new();
    private List<MikrotikProfileResponseDto> profiles = new();
    private List<MikrotikServerResponseDto> servers = new();
    private List<DepartmentResponseDto> departments = new();

    private string? errorMessage;
    private bool isProcessing;

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible)
        {
            createModel = new();
            errorMessage = null;
            await LoadInitialData();
        }
    }

    private async Task LoadInitialData()
    {
        try
        {
            var pTask = MikrotikService.GetAllProfilesAsync();
            var sTask = MikrotikService.GetServersListAsync();
            var dTask = DepartmentService.GetAllAsync();

            profiles = await pTask ?? new();
            servers = await sTask ?? new();
            departments = await dTask ?? new();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load initial data.";
        }
    }

    private async Task HandleSave()
    {
        isProcessing = true;
        errorMessage = null;

        try
        {
            await MikrotikService.CreateUserAsync(createModel);
            await OnUserCreated.InvokeAsync();
            await Close();
        }
        catch (Exception ex)
        {
            // هنا نستخدم التحليل لاستخراج الرسالة النظيفة
            errorMessage = ParseErrorMessage(ex.Message);
        }
        finally
        {
            isProcessing = false;
        }
    }

    // أضف هذه الدالة داخل المودال أيضاً
    private string ParseErrorMessage(string rawMessage)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(rawMessage);
            var root = doc.RootElement;
            if (root.TryGetProperty("errors", out var errors) && errors.GetArrayLength() > 0)
            {
                return errors[0].GetProperty("Message").GetString() ?? rawMessage;
            }
        }
        catch { }
        return rawMessage;
    }

    private async Task Close()
    {
        if (!isProcessing)
        {
            await OnClose.InvokeAsync();
        }
    }
}