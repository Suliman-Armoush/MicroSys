@using UI.Services.Interfaces
@inject IMikrotikService MikrotikService

@if (IsVisible)
{
    <div class="modal fade show d-block app-modal-backdrop" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content danger-zone">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="Close" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4">
                    <p class="mb-0">Delete user <span class="fw-bold text-danger">@Username</span>?</p>
                    <small class="text-muted">This action cannot be undone.</small>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light px-4" @onclick="Close">Cancel</button>
                    <button type="button" class="btn btn-danger px-4 fw-bold" @onclick="ConfirmDelete" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Confirm Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Username { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnUserDeleted { get; set; }

    private bool isSubmitting = false;

    private async Task ConfirmDelete()
    {
        isSubmitting = true;
        var success = await MikrotikService.DeleteUserAsync(Username);
        if (success)
        {
            await OnUserDeleted.InvokeAsync();
            await Close();
        }
        isSubmitting = false;
    }

    private async Task Close() => await OnClose.InvokeAsync();
}
