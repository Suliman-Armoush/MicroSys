@page "/mikrotik-users"
@attribute [Authorize(Roles = "Admin")]
@using UI.Models.Response
@using UI.Services.Interfaces
@using System.Text.Json
@inject IMikrotikService MikrotikService
@inject NavigationManager Navigation

<PageTitle>MikroTik Users - MicroSys</PageTitle>

<div class="admin-page">
    <div class="admin-shell">
        <div class="page-header">
            <div class="page-header-main">
                <span class="page-kicker">MikroTik</span>
                <h1 class="page-title">Network Users</h1>
                <p class="page-subtitle">Track consumption and manage MikroTik user status from one readable table.</p>
            </div>

            <div class="page-actions">
                <button class="btn btn-light" type="button" @onclick='() => Navigation.NavigateTo("/")'>Back</button>
                <button class="btn btn-primary" type="button" @onclick="() => showCreateModal = true">Add User</button>
                <button class="btn btn-outline-danger" type="button" @onclick="() => showResetAllCountersModal = true">Reset Counters</button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger my-3 alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
            </div>
        }

        <div class="toolbar">
            <div class="search-field">
                <input type="text"
                       class="form-control"
                       placeholder="Search users..."
                       @bind="searchTerm"
                       @bind:event="oninput"
                       @onkeyup="HandleSearch" />
            </div>

            @if (isSearching)
            {
                <span class="soft-badge primary">Searching...</span>
            }
        </div>

        <div class="page-card">
            <div class="table-responsive">
                <table class="table table-hover data-table align-middle text-center">
                    <thead>
                        <tr>
                            <th class="text-start">User</th>
                            <th class="text-start">Comments</th>
                            <th>Upload GB</th>
                            <th>Download GB</th>
                            <th>Total GB</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (users == null && string.IsNullOrEmpty(errorMessage))
                        {
                            <tr>
                                <td colspan="6">
                                    <div class="loading-state">
                                        <div class="spinner-border text-primary" role="status"></div>
                                        <p>Loading users...</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else if (users != null && users.Count == 0)
                        {
                            <tr>
                                <td colspan="6">
                                    <div class="empty-state">
                                        <p>No users found.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else if (users != null)
                        {
                            @foreach (var user in users)
                            {
                                <tr>
                                    <td class="text-start fw-bold text-primary">@user.Username</td>
                                    <td class="text-start text-muted">@user.Comment</td>
                                    <td><span class="soft-badge danger">@user.BytesIn.ToString("N2")</span></td>
                                    <td><span class="soft-badge success">@user.BytesOut.ToString("N2")</span></td>
                                    <td><span class="soft-badge primary">@user.Total.ToString("N2")</span></td>
                                    <td>
                                        <div class="data-table-actions">
                                            <button class="btn btn-sm btn-outline-success" type="button" @onclick="() => OpenEnableModal(user.Username)">Enable</button>
                                            <button class="btn btn-sm btn-light" type="button" @onclick="() => OpenDisableModal(user.Username)">Disable</button>
                                            <button class="btn btn-sm btn-outline-warning" type="button" @onclick="() => OpenEditModal(user.Username)">Edit</button>
                                            <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => OpenDeleteModal(user.Username)">Delete</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<CreateMikrotikUserModal IsVisible="showCreateModal" OnClose="() => showCreateModal = false" OnUserCreated="ReloadUsers" />
<EditMikrotikUserModal IsVisible="showEditModal" CurrentUsername="@selectedUsername" OnClose="() => showEditModal = false" OnUserUpdated="ReloadUsers" />
<DeleteMikrotikUserModal IsVisible="showDeleteModal" Username="@selectedUsername" OnClose="() => showDeleteModal = false" OnUserDeleted="ReloadUsers" />
<EnableUserModal IsVisible="showEnableModal" Username="@selectedUsername" OnClose="() => showEnableModal = false" OnUserEnabled="ReloadUsers" />
<DisableUserModal IsVisible="showDisableModal" Username="@selectedUsername" OnClose="() => showDisableModal = false" OnUserDisabled="ReloadUsers" />

@if (showResetAllCountersModal)
{
    <div class="modal fade show d-block app-modal-backdrop" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content danger-zone">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Reset All Counters</h5>
                    <button type="button" class="btn-close" @onclick="CloseResetModal"></button>
                </div>
                <div class="modal-body">
                    <p class="fw-bold text-danger">This action will reset counters for all users.</p>
                    <input type="text" class="form-control text-center" placeholder="Type reset" @bind="resetConfirmationText" />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-light" @onclick="CloseResetModal">Cancel</button>
                    <button class="btn btn-danger" disabled="@(!CanResetCounters)" @onclick="ConfirmResetAllCounters">Reset</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MikrotikUserResponseDto>? users;
    private string? errorMessage;
    private string searchTerm = "";
    private bool isSearching = false;
    private System.Timers.Timer? debounceTimer;
    private bool showCreateModal, showEditModal, showDeleteModal, showEnableModal, showDisableModal, showResetAllCountersModal;
    private string selectedUsername = "";
    private string resetConfirmationText = "";
    private bool CanResetCounters => string.Equals(resetConfirmationText?.Trim(), "reset", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync() => await ReloadUsers();

    private async Task ReloadUsers()
    {
        try
        {
            users = null;
            users = await MikrotikService.GetAllUsersAsync();
        }
        catch (Exception ex) { errorMessage = ParseErrorMessage(ex.Message); }
    }

    private void HandleSearch()
    {
        debounceTimer?.Stop();
        debounceTimer = new System.Timers.Timer(400);
        debounceTimer.Elapsed += async (s, e) =>
        {
            isSearching = true;
            try
            {
                users = string.IsNullOrWhiteSpace(searchTerm) ? await MikrotikService.GetAllUsersAsync() : await MikrotikService.SearchUsersAsync(searchTerm);
            }
            catch (Exception ex) { errorMessage = ParseErrorMessage(ex.Message); }
            isSearching = false;
            await InvokeAsync(StateHasChanged);
        };
        debounceTimer.Start();
    }

    private async Task ConfirmResetAllCounters()
    {
        try
        {
            if (await MikrotikService.ResetAllCountersAsync()) await ReloadUsers();
        }
        catch (Exception ex) { errorMessage = ParseErrorMessage(ex.Message); }
        CloseResetModal();
    }

    // دالة لتحليل رسالة الخطأ القادمة من الـ API (مثل الصورة التي أرسلتها)
    private string ParseErrorMessage(string rawMessage)
    {
        try
        {
            using var doc = JsonDocument.Parse(rawMessage);
            var root = doc.RootElement;
            if (root.TryGetProperty("errors", out var errors) && errors.GetArrayLength() > 0)
            {
                return errors[0].GetProperty("Message").GetString() ?? rawMessage;
            }
        }
        catch { }
        return rawMessage;
    }

    private void CloseResetModal() { showResetAllCountersModal = false; resetConfirmationText = ""; }
    private void OpenEditModal(string u) { selectedUsername = u; showEditModal = true; }
    private void OpenDeleteModal(string u) { selectedUsername = u; showDeleteModal = true; }
    private void OpenEnableModal(string u) { selectedUsername = u; showEnableModal = true; }
    private void OpenDisableModal(string u) { selectedUsername = u; showDisableModal = true; }
}