@* UI/Shared/Components/UserStatusToggle.razor *@
@using UI.Services.Interfaces
@inject IMikrotikService MikrotikService

<div class="d-inline-block">
    @if (IsDisabled)
    {
        <button class="btn btn-sm btn-success"
                @onclick="HandleEnable" disabled="@isPending" title="Enable user">
            @if (isPending)
            {
                <span class="spinner-border spinner-border-sm"></span>
            }
            else
            {
                <span>Enable</span>
            }
        </button>
    }
    else
    {
        <button class="btn btn-sm btn-outline-secondary"
                @onclick="HandleDisable" disabled="@isPending" title="Disable user">
            @if (isPending)
            {
                <span class="spinner-border spinner-border-sm"></span>
            }
            else
            {
                <span>Disable</span>
            }
        </button>
    }

    @* Shows a short local error message when the status change fails. *@
    @if (!string.IsNullOrEmpty(localError))
    {
        <div class="position-absolute badge bg-danger mt-1">
            @localError
        </div>
    }
</div>

@code {
    [Parameter] public string Username { get; set; } = "";
    [Parameter] public bool IsDisabled { get; set; }
    [Parameter] public EventCallback OnStatusChanged { get; set; }

    private bool isPending = false;
    private string? localError;

    private async Task HandleEnable()
    {
        await ExecuteStatusChange(async () => await MikrotikService.EnableUserAsync(Username));
    }

    private async Task HandleDisable()
    {
        await ExecuteStatusChange(async () => await MikrotikService.DisableUserAsync(Username));
    }

    private async Task ExecuteStatusChange(Func<Task<string?>> action)
    {
        isPending = true;
        localError = null;
        
        try
        {
            var error = await action();
            
            if (string.IsNullOrEmpty(error))
            {
                await OnStatusChanged.InvokeAsync();
            }
            else
            {
                localError = error;
                _ = Task.Delay(3000).ContinueWith(_ => { localError = null; InvokeAsync(StateHasChanged); });
            }
        }
        catch (Exception)
        {
            localError = "Connection error";
        }
        finally
        {
            isPending = false;
        }
    }
}
