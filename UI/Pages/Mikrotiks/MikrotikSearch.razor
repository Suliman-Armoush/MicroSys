@using UI.Services.Interfaces
@inject IMikrotikService MikrotikService

<div class="search-container" dir="rtl">
    <div class="input-group shadow-sm">
        <span class="input-group-text bg-white border-end-0">
            <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text"
               class="form-control border-start-0"
               placeholder="ابحث عن مستخدم أو ملاحظة..."
               @bind="searchTerm"
               @bind:event="oninput"
               @onkeyup="OnKeyUp" />
        
        @if (isSearching)
        {
            <span class="input-group-text bg-white">
                <div class="spinner-border spinner-border-sm text-primary"></div>
            </span>
        }
    </div>
</div>

@code {
    private string searchTerm = "";
    private bool isSearching = false;
    private System.Timers.Timer? debounceTimer;

    // حدث نطلقه عندما تنتهي عملية البحث ونرسل النتائج للصفحة الأب
    [Parameter] public EventCallback<List<MikrotikUserResponseDto>> OnSearchCompleted { get; set; }

    private void OnKeyUp()
    {
        debounceTimer?.Stop();
        debounceTimer = new System.Timers.Timer(500); // انتظر نص ثانية بعد آخر حرف
        debounceTimer.Elapsed += async (s, e) => await ExecuteSearch();
        debounceTimer.AutoReset = false;
        debounceTimer.Start();
    }

    private async Task ExecuteSearch()
    {
        isSearching = true;
        await InvokeAsync(StateHasChanged);

        var results = await MikrotikService.SearchUsersAsync(searchTerm);
        
        await OnSearchCompleted.InvokeAsync(results);
        
        isSearching = false;
        await InvokeAsync(StateHasChanged);
    }
}