@page "/reports"
@attribute [Authorize(Roles = "Admin")]

@using UI.Models.Response
@using UI.Services.Interfaces
@inject IReportService ReportService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Reports - MicroSys</PageTitle>

<div class="admin-page">
    <div class="admin-shell">
        <div class="page-header">
            <div class="page-header-main">
                <span class="page-kicker">Reports Center</span>
                <h1 class="page-title">Reports Center</h1>
                <p class="page-subtitle">Export department consumption reports to Excel and review a quick summary in the system.</p>
            </div>

            <div class="page-actions">
                <button class="btn btn-light" type="button" @onclick="GoBack">Back</button>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-lg-6">
                <div class="report-option accent-primary">
                    <div>
                        <span class="soft-badge primary mb-3">Summary</span>
                        <h2 class="h4 mb-2">Department Summary Report</h2>
                        <p class="page-subtitle mb-0">An Excel file with department consumption totals and cost calculations.</p>
                    </div>

                    <button class="btn btn-primary w-100" type="button" @onclick="() => DownloadReport(false)" disabled="@isExporting">
                        @if (isExporting && !isDetailedAction)
                        {
                            <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                            <span>Exporting...</span>
                        }
                        else
                        {
                            <span>Export Summary</span>
                        }
                    </button>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="report-option accent-success">
                    <div>
                        <span class="soft-badge success mb-3">Detailed</span>
                        <h2 class="h4 mb-2">Detailed Department Report</h2>
                        <p class="page-subtitle mb-0">A full Excel file showing each user's consumption inside each department.</p>
                    </div>

                    <button class="btn btn-success w-100" type="button" @onclick="() => DownloadReport(true)" disabled="@isExporting">
                        @if (isExporting && isDetailedAction)
                        {
                            <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                            <span>Exporting...</span>
                        }
                        else
                        {
                            <span>Export Detailed</span>
                        }
                    </button>
                </div>
            </div>
        </div>

        <div class="page-card">
            <div class="page-card-header">
                <h2 class="page-card-title">Current Consumption Summary</h2>
                <span class="soft-badge primary">Departments</span>
            </div>

            @if (isLoadingSummary)
            {
                <div class="loading-state">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p>Loading summary...</p>
                </div>
            }
            else if (summaryData == null || summaryData.Count == 0)
            {
                <div class="empty-state">
                    <p>No summary data is available yet.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover data-table align-middle text-center">
                        <thead>
                            <tr>
                                <th class="text-start">Department</th>
                                <th>Subscribers</th>
                                <th>Consumption GB</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in summaryData)
                            {
                                <tr>
                                    <td class="text-start fw-bold">@item.DepartmentName.ToUpper()</td>
                                    <td><span class="soft-badge primary">@item.ActiveUsersCount</span></td>
                                    <td><span class="soft-badge success">@item.TotalConsumptionGB.ToString("N2")</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<DepartmentConsumptionResponseDto>? summaryData;
    private bool isExporting = false;
    private bool isDetailedAction = false;
    private bool isLoadingSummary = true;

    protected override async Task OnInitializedAsync()
    {
        summaryData = await ReportService.GetDepartmentsSummaryAsync();
        isLoadingSummary = false;
    }

    private async Task DownloadReport(bool isDetailed)
    {
        isExporting = true;
        isDetailedAction = isDetailed;
        try
        {
            byte[]? fileBytes;
            var fileName = isDetailed ? "Detailed_Report.xlsx" : "Summary_Report.xlsx";

            if (isDetailed)
            {
                fileBytes = await ReportService.DownloadDetailedConsumptionExcelAsync();
            }
            else
            {
                fileBytes = await ReportService.DownloadDepartmentConsumptionExcelAsync();
            }

            if (fileBytes != null)
            {
                await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, Convert.ToBase64String(fileBytes));
            }
        }
        finally
        {
            isExporting = false;
            isDetailedAction = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/");
}
