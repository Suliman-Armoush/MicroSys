@* DeleteHostButton.razor *@
<button class="host-item-delete-btn" @onclick="RequestDelete" title="إزالة الجهاز" type="button">
    <i class="bi bi-trash3-fill"></i>
</button>

<style>
    .host-item-delete-btn {
        width: 36px;
        height: 36px;
        border-radius: 10px; /* تصميم Squircle عصري */
        border: none;
        background: linear-gradient(135deg, #ff9a9e 0%, #f6416c 100%);
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        box-shadow: 0 4px 10px rgba(246, 65, 108, 0.2);
    }

        .host-item-delete-btn:hover {
            transform: scale(1.15) rotate(10deg);
            box-shadow: 0 6px 15px rgba(246, 65, 108, 0.4);
            filter: brightness(1.1);
        }

        .host-item-delete-btn:active {
            transform: scale(0.9);
        }

        .host-item-delete-btn i {
            font-size: 1.1rem;
        }
</style>

@code {
    [Parameter] public EventCallback OnClickRequest { get; set; }

    private async Task RequestDelete()
    {
        await OnClickRequest.InvokeAsync();
    }
}