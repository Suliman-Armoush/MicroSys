@page "/departments"
@attribute [Authorize(Roles = "Admin")]
@using UI.Models
@using UI.Models.Enums
@using UI.Services.Interfaces
@inject IDepartmentService DepartmentService
@inject IJSRuntime JS

<PageTitle>Departments - MicroSys</PageTitle>

<div class="admin-page">
    <div class="admin-shell">
        <div class="page-header">
            <div class="page-header-main">
                <span class="page-kicker">Organization</span>
                <h1 class="page-title">Departments</h1>
                <p class="page-subtitle">Define departments, their type, and DVR number for users and reports.</p>
            </div>

            <div class="page-actions">
                <button class="btn btn-primary" type="button" @onclick="OpenCreateModal">
                    Add Department
                </button>
            </div>
        </div>

        <div class="page-card">
            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p>Loading departments...</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover data-table align-middle">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Arabic Name</th>
                                <th>Type</th>
                                <th>DVR Number</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var department in departments)
                            {
                                <tr>
                                    <td><span class="text-muted fw-bold">#@department.Id</span></td>
                                    <td class="fw-bold">@department.Name</td>
                                    <td>@department.ArName</td>
                                    <td><span class="soft-badge primary">@GetTypeName(department.Type)</span></td>
                                    <td><span class="soft-badge warning">@department.DvrNum</span></td>
                                    <td class="text-center">
                                        <div class="data-table-actions">
                                            <button class="btn btn-sm btn-light" type="button" @onclick="() => OpenEditModal(department)">
                                                Edit
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => DeleteDepartment(department.Id)">
                                                Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="departmentModal" tabindex="-1" aria-labelledby="departmentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="departmentModalLabel">@(isEditMode ? "Edit Department" : "Add Department")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="@currentDepartment" OnValidSubmit="@SaveDepartment">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label for="deptName" class="form-label">Department Name</label>
                        <InputText id="deptName" class="form-control" @bind-Value="currentDepartment.Name" />
                        <ValidationMessage For="@(() => currentDepartment.Name)" />
                    </div>
                    <div class="mb-3">
                        <label for="deptArName" class="form-label">Arabic Name</label>
                        <InputText id="deptArName" class="form-control" @bind-Value="currentDepartment.ArName" />
                        <ValidationMessage For="@(() => currentDepartment.ArName)" />
                    </div>
                    <div class="mb-3">
                        <label for="deptType" class="form-label">Department Type</label>
                        <InputSelect id="deptType" class="form-select" @bind-Value="currentDepartment.Type">
                            <option value="">-- Select type --</option>
                            <option value="@DepartmentTypes.Service">Service</option>
                            <option value="@DepartmentTypes.TcShops">TcShops</option>
                            <option value="@DepartmentTypes.Shops">Shops</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => currentDepartment.Type)" />
                    </div>
                    <div class="mb-3">
                        <label for="dvrNum" class="form-label">DVR Number</label>
                        <InputNumber id="dvrNum" class="form-control" @bind-Value="currentDepartment.DvrNum" />
                        <ValidationMessage For="@(() => currentDepartment.DvrNum)" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @(isSaving ? "Saving..." : "Save")
                        </button>
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private List<DepartmentResponseDto> departments = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isEditMode = false;
    private int editingDepartmentId = 0;
    private DepartmentRequestDto currentDepartment = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDepartments();
    }

    private async Task LoadDepartments()
    {
        isLoading = true;
        departments = await DepartmentService.GetAllAsync();
        isLoading = false;
    }

    private void OpenCreateModal()
    {
        isEditMode = false;
        editingDepartmentId = 0;
        currentDepartment = new DepartmentRequestDto
        {
            Type = DepartmentTypes.Service,
            DvrNum = 0
        };
        ShowModal();
    }

    private void OpenEditModal(DepartmentResponseDto department)
    {
        isEditMode = true;
        editingDepartmentId = department.Id;
        currentDepartment = new DepartmentRequestDto
        {
            Name = department.Name,
            ArName = department.ArName,
            Type = department.Type,
            DvrNum = department.DvrNum
        };
        ShowModal();
    }

    private async Task SaveDepartment()
    {
        isSaving = true;
        try
        {
            if (isEditMode)
            {
                await DepartmentService.UpdateAsync(editingDepartmentId, currentDepartment);
            }
            else
            {
                await DepartmentService.CreateAsync(currentDepartment);
            }

            await LoadDepartments();
            CloseModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            await JS.InvokeVoidAsync("alert", "An error occurred: " + ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteDepartment(int id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this department?");
        if (!confirmed)
        {
            return;
        }

        try
        {
            await DepartmentService.DeleteAsync(id);
            await LoadDepartments();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting: {ex.Message}");
            await JS.InvokeVoidAsync("alert", "Delete failed: " + ex.Message);
        }
    }

    private static string GetTypeName(DepartmentTypes type)
    {
        return type switch
        {
            DepartmentTypes.Service => "Service",
            DepartmentTypes.TcShops => "TcShops",
            DepartmentTypes.Shops => "Shops",
            _ => type.ToString()
        };
    }

    private async void ShowModal()
    {
        await JS.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('departmentModal')).show();");
    }

    private async void CloseModal()
    {
        await JS.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('departmentModal'))?.hide();");
    }
}
