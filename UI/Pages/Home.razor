@page "/"
@attribute [Authorize(Roles = "Admin")]

@using UI.Models.Request
@using UI.Models.Response
@using UI.Services.Interfaces

@inject ISysInfosService SysInfosService
@inject IMikrotikService MikrotikService

@inject IJSRuntime JS

<PageTitle>Home - MicroSys 🤪</PageTitle>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>System Settings</h2>

        @if (sysInfo != null)
        {
            <div>
                <button class="btn btn-info me-2" @onclick="TestConnection">
                    Test Connection
                </button>

                <button class="btn btn-warning" @onclick="OpenEditModal">
                    Edit
                </button>
            </div>
        }
    </div>

    @if (isLoading)
    {
        <p>Loading...</p>
    }
    else if (sysInfo == null)
    {
        <div class="alert alert-danger">
            No settings found
        </div>
    }
    else
    {
        <div class="card shadow-sm mb-4 border-0">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <span>MikroTik Settings</span>
                <span class="badge bg-success">Active</span>
            </div>

            <div class="card-body">
                <div class="row g-3">

                    <div class="col-md-4">
                        <div class="info-box">
                            <small>IP Address</small>
                            <div>@sysInfo.MikroTikIp</div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="info-box">
                            <small>Username</small>
                            <div>@sysInfo.Username</div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="info-box d-flex justify-content-between align-items-center">
                            <div>
                                <small>Password</small>
                                <div>@(showPassword ? sysInfo.Password : "••••••••")</div>
                            </div>

                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="TogglePassword">
                                <i class="oi @(showPassword ? "oi-eye-slash" : "oi-eye")"></i>
                            </button>
                        </div>
                    </div>

                    <div class="col-md-12">
                        <div class="info-box highlight dvr-box d-flex justify-content-between align-items-center">
                            <div>
                                <small>DVR Price</small>
                            </div>

                            <div class="price">
                                @sysInfo.DvrPrice
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white">
                Network Pricing Segments
            </div>

            <div class="card-body">

                <table class="table table-bordered text-center align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Segment</th>
                            <th>Range</th>
                            <th>Price</th>
                        </tr>
                    </thead>

                    <tbody>
                        @for (int i = 1; i <= 6; i++)
                        {
                            <tr>
                                <td>Segment @i</td>
                                <td>@GetRange(i)</td>
                                <td class="fw-bold text-success">@GetPrice(i) </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>
    }

</div>

<div class="modal fade" id="sysInfoModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Edit Settings</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <EditForm Model="@editModel" OnValidSubmit="Save">

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label>IP</label>
                            <InputText class="form-control" @bind-Value="editModel.MikroTikIp" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Username</label>
                            <InputText class="form-control" @bind-Value="editModel.Username" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Password</label>
                            <InputText class="form-control" @bind-Value="editModel.Password" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>DVR Price</label>
                            <InputNumber class="form-control" @bind-Value="editModel.DvrPrice" />
                        </div>

                    </div>

                    <hr />

                    <h6>Segments</h6>

                    <div class="row">

                        <div class="col-md-4 mb-2">
                            <InputNumber class="form-control" @bind-Value="editModel.segment1" />
                        </div>

                        <div class="col-md-4 mb-2">
                            <InputNumber class="form-control" @bind-Value="editModel.segment2" />
                        </div>

                        <div class="col-md-4 mb-2">
                            <InputNumber class="form-control" @bind-Value="editModel.segment3" />
                        </div>

                        <div class="col-md-4 mb-2">
                            <InputNumber class="form-control" @bind-Value="editModel.segment4" />
                        </div>

                        <div class="col-md-4 mb-2">
                            <InputNumber class="form-control" @bind-Value="editModel.segment5" />
                        </div>

                        <div class="col-md-4 mb-2">
                            <InputNumber class="form-control" @bind-Value="editModel.segment6" />
                        </div>

                    </div>

                    <div class="mt-3">
                        <button class="btn btn-primary" disabled="@isSaving">
                            @(isSaving ? "Saving..." : "Save")
                        </button>

                        <button type="button" class="btn btn-secondary ms-2" data-bs-dismiss="modal">
                            Cancel
                        </button>
                    </div>

                </EditForm>

            </div>
        </div>
    </div>
</div>

<style>
    .segment-box {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 8px;
        font-size: 20px;
        font-weight: bold;
        border: 1px solid #dee2e6;
    }
</style>

@code {

    private SysInfosResponseDto? sysInfo;
    private SysInfosRequestDto editModel = new();

    private bool isLoading = true;
    private bool isSaving = false;
    private bool showPassword = false;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        isLoading = true;

        var list = await SysInfosService.GetAsync();
        sysInfo = list.FirstOrDefault();

        isLoading = false;
    }

    private void OpenEditModal()
    {
        if (sysInfo == null) return;

        editModel = new SysInfosRequestDto
        {
            MikroTikIp = sysInfo.MikroTikIp,
            Username = sysInfo.Username,
            Password = sysInfo.Password,
            DvrPrice = sysInfo.DvrPrice,
            segment1 = sysInfo.segment1,
            segment2 = sysInfo.segment2,
            segment3 = sysInfo.segment3,
            segment4 = sysInfo.segment4,
            segment5 = sysInfo.segment5,
            segment6 = sysInfo.segment6
        };

        ShowModal();
    }

    private async Task Save()
    {
        if (sysInfo == null) return;

        isSaving = true;

        await SysInfosService.UpdateAsync(sysInfo.Id, editModel);
        await Load();

        CloseModal();

        isSaving = false;
    }

    private async Task TestConnection()
    {
        var result = await MikrotikService.TestConnectionAsync();

        if (result)
            await JS.InvokeVoidAsync("alert", "Connected ✅");
        else
            await JS.InvokeVoidAsync("alert", "Failed ❌");
    }

    private async void ShowModal()
    {
        await JS.InvokeVoidAsync("eval",
            "new bootstrap.Modal(document.getElementById('sysInfoModal')).show()");
    }

    private async void CloseModal()
    {
        await JS.InvokeVoidAsync("eval",
            "bootstrap.Modal.getInstance(document.getElementById('sysInfoModal'))?.hide()");
    }

    private void TogglePassword()
    {
        showPassword = !showPassword;
    }

    private int GetSegmentValue(int i)
    {
        return i switch
        {
            1 => sysInfo?.segment1 ?? 0,
            2 => sysInfo?.segment2 ?? 0,
            3 => sysInfo?.segment3 ?? 0,
            4 => sysInfo?.segment4 ?? 0,
            5 => sysInfo?.segment5 ?? 0,
            6 => sysInfo?.segment6 ?? 0,
            _ => 0
        };
    }

    private string GetRange(int i)
    {
        int start = (i - 1) * 25;

        if (i == 6)
            return $"{start}+";

        int end = i * 25;
        return $"{start} - {end}";
    }

    private double GetPrice(int i)
    {
        return i switch
        {
            1 => sysInfo?.segment1 ?? 0,
            2 => sysInfo?.segment2 ?? 0,
            3 => sysInfo?.segment3 ?? 0,
            4 => sysInfo?.segment4 ?? 0,
            5 => sysInfo?.segment5 ?? 0,
            6 => sysInfo?.segment6 ?? 0,
            _ => 0
        };
    }
}

<style>
    .info-box {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 10px;
        border: 1px solid #e3e3e3;
    }

        .info-box small {
            color: #6c757d;
        }

        .info-box div {
            font-size: 18px;
            font-weight: bold;
        }

    .highlight {
        background: linear-gradient(45deg, #007bff, #6610f2);
        color: white;
        text-align: center;
    }

        .highlight .price {
            font-size: 20px;
        }

    .dvr-box {
        padding: 10px;
    }

        .dvr-box div {
            font-size: 20px;
        }

        .dvr-box .price {
            font-size: 22px;
        }
</style>