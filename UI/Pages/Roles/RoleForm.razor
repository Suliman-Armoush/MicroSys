@page "/roleform/{id:int?}"

@inject IRoleService RoleService
@inject NavigationManager Navigation

<PageTitle>@(IsNew ? "Add Role" : "Edit Role") - MicroSys</PageTitle>

<div class="admin-page">
    <div class="admin-shell">
        <div class="page-header">
            <div class="page-header-main">
                <span class="page-kicker">Access Control</span>
                <h1 class="page-title">@(IsNew ? "Add Role" : "Edit Role")</h1>
                <p class="page-subtitle">Enter the role name that will appear in user permissions.</p>
            </div>
        </div>

        <div class="page-card p-3">
            <EditForm Model="@roleDto" OnValidSubmit="@HandleSubmit">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label class="form-label">Role Name</label>
                    <InputText class="form-control" @bind-Value="roleDto.Name" />
                    <ValidationMessage For="@(() => roleDto.Name)" />
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @(isSubmitting ? "Saving..." : "Save")
                    </button>
                    <a href="/roles" class="btn btn-light">Cancel</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    private bool IsNew => Id == null || Id == 0;
    private bool isSubmitting = false;
    private RoleRequestDto roleDto = new();

    protected override async Task OnInitializedAsync()
    {
        if (!IsNew && Id.HasValue)
        {
            var existing = await RoleService.GetByIdAsync(Id.Value);
            roleDto.Name = existing.Name;
        }
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        try
        {
            if (IsNew)
            {
                await RoleService.CreateAsync(roleDto);
            }
            else
            {
                await RoleService.UpdateAsync(Id!.Value, roleDto);
            }

            Navigation.NavigateTo("/roles");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
