@page "/roles"
@attribute [Authorize(Roles = "Admin")]
@inject IRoleService RoleService
@inject IJSRuntime JS

<PageTitle>Roles - MicroSys</PageTitle>

<div class="admin-page">
    <div class="admin-shell">
        <div class="page-header">
            <div class="page-header-main">
                <span class="page-kicker">Access Control</span>
                <h1 class="page-title">Roles</h1>
                <p class="page-subtitle">Organize user permissions with clear, easy-to-review roles.</p>
            </div>

            <div class="page-actions">
                <button class="btn btn-primary" type="button" @onclick="OpenCreateModal">
                    Add Role
                </button>
            </div>
        </div>

        <div class="page-card">
            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p>Loading roles...</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover data-table align-middle">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Role Name</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in roles)
                            {
                                <tr>
                                    <td><span class="text-muted fw-bold">#@role.Id</span></td>
                                    <td><span class="soft-badge primary">@role.Name</span></td>
                                    <td class="text-center">
                                        <div class="data-table-actions">
                                            <button class="btn btn-sm btn-light" type="button" @onclick="() => OpenEditModal(role)">
                                                Edit
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => DeleteRole(role.Id)">
                                                Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="roleModal" tabindex="-1" aria-labelledby="roleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="roleModalLabel">@(isEditMode ? "Edit Role" : "Add Role")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="@currentRole" OnValidSubmit="@SaveRole">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label for="roleName" class="form-label">Role Name</label>
                        <InputText id="roleName" class="form-control" @bind-Value="currentRole.Name" />
                        <ValidationMessage For="@(() => currentRole.Name)" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @(isSaving ? "Saving..." : "Save")
                        </button>
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private List<RoleResponseDto> roles = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isEditMode = false;
    private int editingRoleId = 0;
    private RoleRequestDto currentRole = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadRoles();
    }

    private async Task LoadRoles()
    {
        isLoading = true;
        roles = await RoleService.GetAllAsync();
        isLoading = false;
    }

    private void OpenCreateModal()
    {
        isEditMode = false;
        editingRoleId = 0;
        currentRole = new RoleRequestDto();
        ShowModal();
    }

    private void OpenEditModal(RoleResponseDto role)
    {
        isEditMode = true;
        editingRoleId = role.Id;
        currentRole = new RoleRequestDto { Name = role.Name };
        ShowModal();
    }

    private async Task SaveRole()
    {
        isSaving = true;
        try
        {
            if (isEditMode)
            {
                await RoleService.UpdateAsync(editingRoleId, currentRole);
            }
            else
            {
                await RoleService.CreateAsync(currentRole);
            }

            await LoadRoles();
            CloseModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            await JS.InvokeVoidAsync("alert", "An error occurred: " + ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteRole(int id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Delete this role?");
        if (!confirmed)
        {
            return;
        }

        try
        {
            await RoleService.DeleteAsync(id);
            await LoadRoles();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting: {ex.Message}");
            await JS.InvokeVoidAsync("alert", "Delete failed: " + ex.Message);
        }
    }

    private async void ShowModal()
    {
        await JS.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('roleModal')).show();");
    }

    private async void CloseModal()
    {
        await JS.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('roleModal'))?.hide();");
    }
}
