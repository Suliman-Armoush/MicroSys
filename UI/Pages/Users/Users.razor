@page "/users"
@attribute [Authorize(Roles = "Admin")]

@using UI.Models.Request
@using UI.Models.Response
@using UI.Services.Interfaces

@inject IUserService UserService
@inject IRoleService RoleService
@inject IDepartmentService DepartmentService
@inject IJSRuntime JS

<PageTitle>Users - MicroSys</PageTitle>

<div class="admin-page">
    <div class="admin-shell">
        <div class="page-header">
            <div class="page-header-main">
                <span class="page-kicker">Administration</span>
                <h1 class="page-title">Users</h1>
                <p class="page-subtitle">Review users and connect each account to the right role and department.</p>
            </div>

            <div class="page-actions">
                <button class="btn btn-primary" type="button" @onclick="OpenCreateModal">
                    Add User
                </button>
            </div>
        </div>

        <div class="page-card">
            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p>Loading users...</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover data-table align-middle">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Username</th>
                                <th>Role</th>
                                <th>Department</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in users)
                            {
                                <tr>
                                    <td><span class="text-muted fw-bold">#@user.Id</span></td>
                                    <td>
                                        <div class="d-inline-flex align-items-center gap-2 fw-bold">
                                            <span class="avatar-circle" aria-hidden="true">@GetInitial(user.Name)</span>
                                            <span>@user.Name</span>
                                        </div>
                                    </td>
                                    <td><span class="text-muted fw-bold">@user.UserName</span></td>
                                    <td><span class="soft-badge primary">@user.Role?.Name</span></td>
                                    <td><span class="soft-badge success">@user.Department?.Name</span></td>
                                    <td class="text-center">
                                        <div class="data-table-actions">
                                            <button class="btn btn-sm btn-light" type="button" @onclick="() => OpenEditModal(user)">
                                                Edit
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => DeleteUser(user.Id)">
                                                Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(isEditMode ? "Edit User" : "Add User")</h5>
                <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <EditForm Model="@currentUser" OnValidSubmit="SaveUser">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="currentUser.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <InputText class="form-control" @bind-Value="currentUser.UserName" />
                    </div>

                    @if (!isEditMode)
                    {
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <InputText type="password" class="form-control" @bind-Value="currentUser.Password" />
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <InputSelect class="form-select" @bind-Value="currentUser.RoleId">
                            <option value="">-- Select --</option>
                            @foreach (var role in roles)
                            {
                                <option value="@role.Id">@role.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Department</label>
                        <InputSelect class="form-select" @bind-Value="currentUser.DepartmentId">
                            <option value="">-- Select --</option>
                            @foreach (var dept in departments)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" type="submit" disabled="@isSaving">
                            @(isSaving ? "Saving..." : "Save")
                        </button>

                        <button class="btn btn-light" type="button" data-bs-dismiss="modal">
                            Cancel
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private List<UserResponseDto> users = new();
    private List<RoleResponseDto> roles = new();
    private List<DepartmentResponseDto> departments = new();
    private UserRequestDto currentUser = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isEditMode = false;
    private int editingId;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        users = await UserService.GetAllAsync();
        roles = await RoleService.GetAllAsync();
        departments = await DepartmentService.GetAllAsync();
        isLoading = false;
    }

    private void OpenCreateModal()
    {
        isEditMode = false;
        currentUser = new UserRequestDto();
        ShowModal();
    }

    private void OpenEditModal(UserResponseDto user)
    {
        isEditMode = true;
        editingId = user.Id;

        currentUser = new UserRequestDto
        {
            Name = user.Name,
            UserName = user.UserName,
            RoleId = user.Role?.Id,
            DepartmentId = user.Department?.Id
        };

        ShowModal();
    }

    private async Task SaveUser()
    {
        isSaving = true;

        try
        {
            if (isEditMode)
            {
                await UserService.UpdateAsync(editingId, currentUser);
            }
            else
            {
                await UserService.CreateAsync(currentUser);
            }

            await LoadData();
            CloseModal();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteUser(int id)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Delete this user?");
        if (!confirm)
        {
            return;
        }

        await UserService.DeleteAsync(id);
        await LoadData();
    }

    private static string GetInitial(string? name)
    {
        return string.IsNullOrWhiteSpace(name) ? "U" : name.Trim()[0].ToString();
    }

    private async void ShowModal()
    {
        await JS.InvokeVoidAsync("eval",
            "new bootstrap.Modal(document.getElementById('userModal')).show()");
    }

    private async void CloseModal()
    {
        await JS.InvokeVoidAsync("eval",
            "bootstrap.Modal.getInstance(document.getElementById('userModal'))?.hide()");
    }
}
